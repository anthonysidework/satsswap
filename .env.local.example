# DEX API Keys — replace with real keys when integrating
RICHSWAP_API_KEY=
LUMINEX_API_KEY=
MAGIC_EDEN_API_KEY=

# Unisat Open API key (used for BRC-20 portfolio balances)
UNISAT_API_KEY=

# OKX DEX aggregator — needed for PSBT construction (swap execution)
# Price quotes use OKX's FREE public exchange API (no key needed)
# Register for the DEX key at: https://www.okx.com/web3/build/dev-portal
OKX_DEX_API_KEY=
OKX_DEX_SECRET_KEY=
OKX_DEX_PASSPHRASE=

# Bitcoin indexer (Maestro or Hiro recommended for v1)
MAESTRO_API_KEY=

# Protocol treasury — receives the 0.15% swap fee
NEXT_PUBLIC_PROTOCOL_FEE_ADDRESS=bc1qplaceholderaddresshere

# Fee in basis points (15 = 0.15%)
NEXT_PUBLIC_PROTOCOL_FEE_BPS=15

# Environment
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_MEMPOOL_URL=https://mempool.space
